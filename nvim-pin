#!/usr/bin/env bash

set -eEu -o pipefail

usage() {
  cat <<EOF
Usage:
  $(basename "${BASH_SOURCE[0]}")
  $(basename "${BASH_SOURCE[0]}") <repo> <days>

List, update, or add pinned plugin commits in init.lua.

Arguments:
  repo   GitHub repo as owner/repo or https://github.com/owner/repo
  days   Non-negative integer; 0 selects the latest default-branch commit

Environment:
  INIT_LUA        Override the init.lua path
  LAZY_LOCK_JSON  Override the lazy-lock.json path
  XDG_CONFIG_HOME Config root used for nvim files; defaults to ~/.config
  NVIM_PIN_COLOR  auto, always, or never; defaults to auto
EOF
  exit "${1:-1}"
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

normalize_repo() {
  local repo="$1"

  repo="${repo%%\?*}"
  repo="${repo%%#*}"
  repo="${repo#https://github.com/}"
  repo="${repo#http://github.com/}"
  repo="${repo#github.com/}"
  repo="${repo%/}"
  repo="${repo%.git}"

  if [[ ! "$repo" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
    die "repo must be owner/repo or https://github.com/owner/repo: $1"
  fi

  printf '%s\n' "$repo"
}

days_ago_utc() {
  local days="$1"

  if date -u -v-"${days}"d '+%Y-%m-%dT%H:%M:%SZ' >/dev/null 2>&1; then
    date -u -v-"${days}"d '+%Y-%m-%dT%H:%M:%SZ'
    return
  fi

  if date -u -d "${days} days ago" '+%Y-%m-%dT%H:%M:%SZ' >/dev/null 2>&1; then
    date -u -d "${days} days ago" '+%Y-%m-%dT%H:%M:%SZ'
    return
  fi

  die "could not compute a UTC cutoff with this date implementation"
}

date_to_epoch() {
  local date="$1"

  if date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$date" '+%s' >/dev/null 2>&1; then
    date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$date" '+%s'
    return
  fi

  if date -u -d "$date" '+%s' >/dev/null 2>&1; then
    date -u -d "$date" '+%s'
    return
  fi

  return 1
}

age_days() {
  local date="$1"
  local epoch
  local now
  local diff
  local days

  epoch="$(date_to_epoch "$date")" || {
    printf 'unknown'
    return
  }

  now="$(date -u '+%s')"
  diff=$((now - epoch))
  if (( diff < 0 )); then
    diff=0
  fi

  days=$((diff / 86400))
  if (( days == 1 )); then
    printf '1 day'
  else
    printf '%s days' "$days"
  fi
}

color_enabled() {
  case "${NVIM_PIN_COLOR:-auto}" in
    always)
      return 0
      ;;
    auto)
      [[ -t 1 && -z "${NO_COLOR:-}" ]]
      ;;
    never)
      return 1
      ;;
    *)
      die "NVIM_PIN_COLOR must be auto, always, or never: ${NVIM_PIN_COLOR}"
      ;;
  esac
}

fetch_commit() {
  local repo="$1"
  local days="$2"
  local args=(--method GET "repos/${repo}/commits" -f per_page=1)
  local sha

  if (( days > 0 )); then
    args+=(-f "until=$(days_ago_utc "$days")")
  fi

  if ! sha="$(gh api "${args[@]}" --jq '.[0].sha')"; then
    die "failed to fetch commits for ${repo} with gh api"
  fi

  if [[ ! "$sha" =~ ^[0-9a-f]{40}$ ]]; then
    die "gh api did not return a commit SHA for ${repo}"
  fi

  printf '%s\n' "$sha"
}

init_lua_path() {
  local config_home="${XDG_CONFIG_HOME:-${HOME}/.config}"

  printf '%s\n' "${INIT_LUA:-${config_home}/nvim/init.lua}"
}

lazy_lock_path() {
  local config_home="${XDG_CONFIG_HOME:-${HOME}/.config}"

  printf '%s\n' "${LAZY_LOCK_JSON:-${config_home}/nvim/lazy-lock.json}"
}

plugin_commits() {
  local mode="$1"
  shift

  perl - "$mode" "$@" <<'PERL'
use strict;
use warnings;
use File::Basename qw(dirname);
use File::Temp qw(tempfile);
use JSON::PP qw(decode_json);

my ($mode, @args) = @ARGV;

sub fail {
  print STDERR "error: $_[0]\n";
  exit 1;
}

sub read_file {
  my ($path) = @_;

  open my $fh, '<', $path or fail("could not read $path: $!");
  local $/;
  my $text = <$fh>;
  close $fh or fail("could not close $path: $!");

  return $text;
}

sub write_file {
  my ($path, $text) = @_;

  my $dir = dirname($path);
  my ($fh, $tmp_path) = tempfile('.nvim-pin.XXXXXX', DIR => $dir, UNLINK => 0);
  my @stat = stat($path);

  print {$fh} $text or do {
    unlink $tmp_path;
    fail("could not write $tmp_path: $!");
  };
  close $fh or do {
    unlink $tmp_path;
    fail("could not close $tmp_path: $!");
  };

  if (@stat) {
    chmod($stat[2] & 0777, $tmp_path) or do {
      unlink $tmp_path;
      fail("could not set permissions on $tmp_path: $!");
    };
  }

  rename $tmp_path, $path or do {
    unlink $tmp_path;
    fail("could not replace $path: $!");
  };
}

sub validate_repo {
  my ($repo) = @_;
  return $repo =~ /\A[A-Za-z0-9_.-]+\/[A-Za-z0-9_.-]+\z/;
}

sub validate_commit {
  my ($commit) = @_;
  return $commit =~ /\A[0-9a-f]{40}\z/;
}

sub validate_lock_name {
  my ($name, $context) = @_;
  fail("$context has an invalid lazy-lock name")
    if !defined($name) || $name eq '' || $name =~ /[\t\r\n]/;
}

sub default_lock_name {
  my ($repo) = @_;

  $repo =~ m{/([^/]+)\z} or fail("invalid repo: $repo");
  return $1;
}

sub skip_lua_long_bracket {
  my ($text, $pos) = @_;

  return undef unless substr($text, $pos, 1) eq '[';
  return undef unless substr($text, $pos) =~ /\A\[(=*)\[/;

  my $equals = $1;
  my $close = ']' . $equals . ']';
  my $body_pos = $pos + 2 + length($equals);
  my $end = index($text, $close, $body_pos);

  return $end < 0 ? length($text) : $end + length($close);
}

sub skip_lua_string {
  my ($text, $pos) = @_;
  my $quote = substr($text, $pos, 1);
  my $len = length($text);

  $pos++;
  while ($pos < $len) {
    my $ch = substr($text, $pos, 1);
    if ($ch eq "\\") {
      $pos += 2;
      next;
    }

    $pos++;
    last if $ch eq $quote;
  }

  return $pos;
}

sub skip_lua_comment {
  my ($text, $pos) = @_;
  my $long_end = skip_lua_long_bracket($text, $pos + 2);
  return $long_end if defined $long_end;

  my $end = index($text, "\n", $pos + 2);

  return $end < 0 ? length($text) : $end + 1;
}

sub extract_lua_table {
  my ($text, $open_pos) = @_;
  my $len = length($text);
  my $depth = 0;
  my $pos = $open_pos;

  return undef unless substr($text, $open_pos, 1) eq '{';

  while ($pos < $len) {
    if (substr($text, $pos, 2) eq '--') {
      $pos = skip_lua_comment($text, $pos);
      next;
    }

    my $ch = substr($text, $pos, 1);
    if ($ch eq '[') {
      my $long_end = skip_lua_long_bracket($text, $pos);
      if (defined $long_end) {
        $pos = $long_end;
        next;
      }
    }
    if ($ch eq "'" || $ch eq '"') {
      $pos = skip_lua_string($text, $pos);
      next;
    }
    if ($ch eq '{') {
      $depth++;
    } elsif ($ch eq '}') {
      $depth--;
      return substr($text, $open_pos, $pos - $open_pos + 1) if $depth == 0;
    }

    $pos++;
  }

  return undef;
}

sub find_top_level_name {
  my ($table) = @_;
  my $len = length($table);
  my $depth = 0;
  my $pos = 0;

  while ($pos < $len) {
    if (substr($table, $pos, 2) eq '--') {
      $pos = skip_lua_comment($table, $pos);
      next;
    }

    my $ch = substr($table, $pos, 1);
    if ($ch eq '[') {
      my $long_end = skip_lua_long_bracket($table, $pos);
      if (defined $long_end) {
        $pos = $long_end;
        next;
      }
    }
    if ($ch eq "'" || $ch eq '"') {
      $pos = skip_lua_string($table, $pos);
      next;
    }
    if ($ch eq '{') {
      $depth++;
      $pos++;
      next;
    }
    if ($ch eq '}') {
      $depth--;
      $pos++;
      next;
    }

    if ($depth == 1) {
      my $prev = $pos == 0 ? '' : substr($table, $pos - 1, 1);
      if ($prev !~ /[A-Za-z0-9_]/ && substr($table, $pos) =~ /\Aname[ \t\r\n]*=[ \t\r\n]*(["'])([^\t\r\n"']+)\1/) {
        return $2;
      }
    }

    $pos++;
  }

  return undef;
}

sub find_plugin_spec_tables {
  my ($text, $repo) = @_;
  my @tables;
  my $len = length($text);
  my $pos = 0;

  while ($pos < $len) {
    if (substr($text, $pos, 2) eq '--') {
      $pos = skip_lua_comment($text, $pos);
      next;
    }

    my $ch = substr($text, $pos, 1);
    if ($ch eq '[') {
      my $long_end = skip_lua_long_bracket($text, $pos);
      if (defined $long_end) {
        $pos = $long_end;
        next;
      }
    }
    if ($ch eq "'" || $ch eq '"') {
      $pos = skip_lua_string($text, $pos);
      next;
    }

    if ($ch eq '{') {
      my $probe = $pos + 1;
      $probe++ while $probe < $len && substr($text, $probe, 1) =~ /[ \t\r\n]/;

      if (substr($text, $probe) =~ /\A(["'])\Q$repo\E\1/) {
        my $table = extract_lua_table($text, $pos);
        fail("could not parse lazy plugin spec for $repo") unless defined $table;

        push @tables, $table;
        $pos += length($table);
        next;
      }
    }

    $pos++;
  }

  return @tables;
}

sub explicit_lock_names {
  my ($text, @entries) = @_;
  my %names;

  for my $entry (@entries) {
    my $repo = $entry->{repo};

    for my $table (find_plugin_spec_tables($text, $repo)) {
      my $name = find_top_level_name($table);
      next unless defined $name;
      validate_lock_name($name, $repo);

      if (exists($names{$repo}) && $names{$repo} ne $name) {
        fail("conflicting lazy plugin names for $repo: $names{$repo}, $name");
      }

      $names{$repo} = $name;
    }
  }

  return \%names;
}

sub read_lock_commits {
  my ($path) = @_;
  my $decoded = eval { decode_json(read_file($path)) };
  my %locks;

  fail("$path is not valid JSON") if $@ || ref($decoded) ne 'HASH';

  for my $name (keys %{$decoded}) {
    validate_lock_name($name, "lazy-lock entry");

    my $entry = $decoded->{$name};
    fail("$path entry $name is not an object") unless ref($entry) eq 'HASH';
    fail("$path entry $name has an invalid commit")
      unless validate_commit($entry->{commit} // '');

    $locks{$name} = $entry->{commit};
  }

  return \%locks;
}

sub find_table {
  my ($text) = @_;

  if ($text !~ /^([ \t]*local[ \t]+plugin_commits[ \t]*=[ \t]*\{[ \t]*(?:--[^\n]*)?\n)(.*?)(^[ \t]*\}[ \t]*;?[ \t]*(?:--[^\n]*)?$)/ms) {
    fail('plugin_commits table not found');
  }

  my ($start, $body, $end) = ($1, $2, $3);
  my $prefix = substr($text, 0, $-[0]);
  my $suffix = substr($text, $+[0]);
  my $body_line = 1 + (() = ($prefix . $start) =~ /\n/g);

  return {
    prefix => $prefix,
    start => $start,
    body => $body,
    end => $end,
    suffix => $suffix,
    body_line => $body_line,
  };
}

sub parse_entries {
  my ($table) = @_;
  my @lines = split /\n/, $table->{body}, -1;
  my @entries;
  my %seen;

  pop @lines if @lines && $lines[-1] eq '';

  for my $idx (0 .. $#lines) {
    my $line = $lines[$idx];
    my $line_no = $table->{body_line} + $idx;

    next if $line =~ /^[ \t]*$/;

    if ($line =~ /^([ \t]*)\[\x27([^\x27]+)\x27\]([ \t]*=[ \t]*)\x27([0-9a-f]{40})\x27([ \t]*,[ \t]*)(.*)$/) {
      my ($repo, $commit, $tail) = ($2, $4, $6);

      if ($tail =~ /\S/ && $tail !~ /^[ \t]*--/) {
        fail("invalid trailing content in plugin_commits at line $line_no");
      }
      if (!validate_repo($repo)) {
        fail("invalid repo in plugin_commits at line $line_no: $repo");
      }
      if ($seen{$repo}) {
        fail("duplicate plugin_commits entry for $repo at line $line_no");
      }

      $seen{$repo} = 1;
      push @entries, {
        repo => $repo,
        commit => $commit,
        line => $line,
      };
      next;
    }

    fail("unsupported plugin_commits line $line_no: $line");
  }

  return @entries;
}

sub sort_entries {
  return sort {
    lc($a->{repo}) cmp lc($b->{repo}) || $a->{repo} cmp $b->{repo}
  } @_;
}

sub update_entry {
  my ($entry, $commit) = @_;

  $entry->{line} =~ s/(\[\x27\Q$entry->{repo}\E\x27\][ \t]*=[ \t]*\x27)[0-9a-f]{40}(\x27[ \t]*,)/$1$commit$2/
    or fail("could not update plugin_commits entry for $entry->{repo}");
  $entry->{commit} = $commit;
}

if ($mode eq 'current') {
  @args == 2 or fail('internal error: current expects init_lua and repo');
  my ($path, $repo) = @args;
  validate_repo($repo) or fail("invalid repo: $repo");

  my $table = find_table(read_file($path));
  my @entries = parse_entries($table);
  for my $entry (@entries) {
    if ($entry->{repo} eq $repo) {
      print "$entry->{commit}\n";
      last;
    }
  }
  exit 0;
}

if ($mode eq 'list') {
  @args == 2 or fail('internal error: list expects init_lua and lazy_lock');
  my ($path, $lock_path) = @args;

  my $text = read_file($path);
  my $table = find_table($text);
  my @entries = parse_entries($table);
  my $names = explicit_lock_names($text, @entries);
  my $locks = read_lock_commits($lock_path);

  for my $entry (@entries) {
    my $lock_name = $names->{$entry->{repo}} // default_lock_name($entry->{repo});
    my $lock_commit = $locks->{$lock_name} // '';
    print join("\t", $entry->{repo}, $entry->{commit}, $lock_name, $lock_commit), "\n";
  }
  exit 0;
}

if ($mode eq 'upsert') {
  @args == 3 or fail('internal error: upsert expects init_lua, repo, commit');
  my ($path, $repo, $commit) = @args;
  validate_repo($repo) or fail("invalid repo: $repo");
  validate_commit($commit) or fail("invalid commit: $commit");

  my $text = read_file($path);
  my $table = find_table($text);
  my @entries = parse_entries($table);
  my $found = 0;

  for my $entry (@entries) {
    if ($entry->{repo} eq $repo) {
      update_entry($entry, $commit);
      $found = 1;
      last;
    }
  }

  if (!$found) {
    push @entries, {
      repo => $repo,
      commit => $commit,
      line => "  [\x27$repo\x27] = \x27$commit\x27,",
    };
  }

  @entries = sort_entries(@entries);
  my @lines = map { $_->{line} } @entries;
  my $body = @lines ? join("\n", @lines) . "\n" : '';
  my $updated = $table->{prefix} . $table->{start} . $body . $table->{end} . $table->{suffix};
  write_file($path, $updated);
  exit 0;
}

fail("internal error: unknown plugin_commits mode: $mode");
PERL
}

current_commit() {
  local repo="$1"
  local init_lua="$2"

  plugin_commits current "$init_lua" "$repo"
}

list_commits() {
  local init_lua="$1"
  local lazy_lock="$2"

  plugin_commits list "$init_lua" "$lazy_lock"
}

upsert_commit() {
  local repo="$1"
  local commit="$2"
  local init_lua="$3"

  plugin_commits upsert "$init_lua" "$repo" "$commit"
}

fetch_status_rows() {
  local commits="$1"
  local query_vars=''
  local query_body=''
  local query
  local response
  local repo
  local commit
  local _lock_name
  local _lock_commit
  local owner
  local name
  local separator=''
  local index=0
  local args=()

  while IFS=$'\t' read -r repo commit _lock_name _lock_commit; do
    owner="${repo%%/*}"
    name="${repo#*/}"

    query_vars+="${separator}\$owner${index}: String!, \$name${index}: String!, \$commit${index}: GitObjectID!"
    query_body+="
  r${index}: repository(owner: \$owner${index}, name: \$name${index}) {
    defaultBranchRef {
      target {
        __typename
        ... on Commit {
          oid
          committedDate
        }
      }
    }
    pinned: object(oid: \$commit${index}) {
      __typename
      ... on Commit {
        oid
        committedDate
      }
    }
  }"
    args+=(-F "owner${index}=${owner}" -F "name${index}=${name}" -F "commit${index}=${commit}")
    separator=', '
    index=$((index + 1))
  done <<< "$commits"

  query="query(${query_vars}) {${query_body}
}"

  if ! response="$(gh api graphql -f "query=${query}" "${args[@]}")"; then
    die "failed to fetch plugin statuses with gh api graphql"
  fi

  STATUS_COMMITS="$commits" perl -MJSON::PP -e '
    use strict;
    use warnings;

    sub fail {
      print STDERR "error: $_[0]\n";
      exit 1;
    }

    sub valid_sha {
      return defined $_[0] && $_[0] =~ /\A[0-9a-f]{40}\z/;
    }

    sub valid_date {
      return defined $_[0] && $_[0] =~ /\A[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z\z/;
    }

    my $json = do { local $/; <STDIN> };
    my $decoded = eval { decode_json($json) };
    fail("gh api graphql returned invalid JSON") if $@ || ref($decoded) ne "HASH";

    if (ref($decoded->{errors}) eq "ARRAY" && @{$decoded->{errors}}) {
      my @messages = map { ref($_) eq "HASH" ? ($_->{message} // "unknown error") : "unknown error" } @{$decoded->{errors}};
      fail("gh api graphql returned errors: " . join("; ", @messages));
    }

    my $data = $decoded->{data};
    fail("gh api graphql response missing data") unless ref($data) eq "HASH";

    my @pins = grep { length } split /\n/, $ENV{STATUS_COMMITS} // "";
    for my $index (0 .. $#pins) {
      my ($repo, $commit, $lock_name, $lock_commit) = split /\t/, $pins[$index], 4;
      fail("internal error: malformed status input at row " . ($index + 1))
        unless defined $repo && defined $commit && defined $lock_name && defined $lock_commit
          && valid_sha($commit)
          && $lock_name ne ""
          && $lock_name !~ /[\t\r\n]/
          && ($lock_commit eq "" || valid_sha($lock_commit));

      my $repo_data = $data->{"r$index"};
      fail("$repo: repository not found") unless ref($repo_data) eq "HASH";

      my $pinned = $repo_data->{pinned};
      fail("$repo\@$commit: pinned object not found") unless ref($pinned) eq "HASH";
      fail("$repo\@$commit: pinned object is not a commit")
        unless ($pinned->{__typename} // "") eq "Commit";
      fail("$repo\@$commit: pinned object returned invalid SHA")
        unless valid_sha($pinned->{oid}) && $pinned->{oid} eq $commit;
      fail("$repo\@$commit: pinned object returned invalid commit date")
        unless valid_date($pinned->{committedDate});

      my $default_ref = $repo_data->{defaultBranchRef};
      fail("$repo: default branch not found") unless ref($default_ref) eq "HASH";

      my $latest = $default_ref->{target};
      fail("$repo: default branch target not found") unless ref($latest) eq "HASH";
      fail("$repo: default branch target is not a commit")
        unless ($latest->{__typename} // "") eq "Commit";
      fail("$repo: default branch returned invalid SHA")
        unless valid_sha($latest->{oid});
      fail("$repo: default branch returned invalid commit date")
        unless valid_date($latest->{committedDate});

      print join("\t", $repo, $commit, $pinned->{committedDate}, $latest->{oid}, $lock_name, $lock_commit), "\n";
    }
  ' <<< "$response"
}

print_status_row() {
  local repo="$1"
  local commit="$2"
  local commit_age="$3"
  local available="$4"
  local lock_mismatch="$5"
  local use_color="$6"
  local repo_col
  local commit_col
  local age_col
  local available_col

  printf -v repo_col '%-42s' "$repo"
  printf -v commit_col '%-40s' "$commit"
  printf -v age_col '%-9s' "$commit_age"
  available_col="$available"

  if (( use_color != 0 && lock_mismatch != 0 )); then
    repo_col=$'\033[31m'"${repo_col}"$'\033[0m'
    commit_col=$'\033[31m'"${commit_col}"$'\033[0m'
    age_col=$'\033[31m'"${age_col}"$'\033[0m'
    available_col=$'\033[31m'"${available_col}"$'\033[0m'
  fi

  if [[ "$available" == "yes" && "$use_color" -ne 0 ]]; then
    available_col=$'\033[32m'"${available}"$'\033[0m'
  fi

  printf '%s %s %s %s\n' "$repo_col" "$commit_col" "$age_col" "$available_col"
}

list_status() {
  local init_lua="$1"
  local lazy_lock="$2"
  local repo
  local commit
  local commit_date
  local commit_age
  local latest_commit
  local _lock_name
  local lock_commit
  local lock_mismatch
  local available
  local commits
  local rows
  local use_color=0

  if color_enabled; then
    use_color=1
  fi

  commits="$(list_commits "$init_lua" "$lazy_lock")"
  if [[ -z "$commits" ]]; then
    printf 'no pinned plugins found\n'
    return
  fi

  rows="$(fetch_status_rows "$commits")"
  [[ -n "$rows" ]] || die "gh api graphql did not return any plugin statuses"

  printf '%-42s %-40s %-9s %s\n' 'repo' 'commit' 'age' 'newer'
  while IFS=$'\t' read -r repo commit commit_date latest_commit _lock_name lock_commit; do
    commit_age="$(age_days "$commit_date")"
    available='no'
    if [[ "$latest_commit" != "$commit" ]]; then
      available='yes'
    fi
    lock_mismatch=0
    if [[ "$lock_commit" != "$commit" ]]; then
      lock_mismatch=1
    fi
    print_status_row "$repo" "$commit" "$commit_age" "$available" "$lock_mismatch" "$use_color"
  done <<< "$rows"
}

main() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage 0
  fi

  if [[ $# -ne 0 && $# -ne 2 ]]; then
    usage 2
  fi

  local repo
  local days
  local init_lua
  local lazy_lock
  local old_commit
  local new_commit

  init_lua="$(init_lua_path)"
  [[ -f "$init_lua" ]] || die "init.lua not found: $init_lua"
  command -v gh >/dev/null 2>&1 || die "gh CLI is required"

  if [[ $# -eq 0 ]]; then
    lazy_lock="$(lazy_lock_path)"
    [[ -f "$lazy_lock" ]] || die "lazy-lock.json not found: $lazy_lock"
    list_status "$init_lua" "$lazy_lock"
    return
  fi

  repo="$1"
  days="$2"

  if [[ ! "$days" =~ ^[0-9]+$ ]]; then
    die "days must be a non-negative integer: $days"
  fi
  days=$((10#$days))

  repo="$(normalize_repo "$repo")"

  old_commit="$(current_commit "$repo" "$init_lua")"
  new_commit="$(fetch_commit "$repo" "$days")"
  upsert_commit "$repo" "$new_commit" "$init_lua"

  if [[ -z "$old_commit" ]]; then
    printf 'Added %s: %s\n' "$repo" "$new_commit"
  elif [[ "$old_commit" == "$new_commit" ]]; then
    printf '%s already pinned to %s\n' "$repo" "$new_commit"
  else
    printf 'Updated %s: %s -> %s\n' "$repo" "$old_commit" "$new_commit"
  fi
}

main "$@"
